# Backend API base URL (embedded at build time via Vite)
# Must be accessible from the user's browser, not just the container network
# Local dev: point directly at backend
# Production: connects directly to the global API
VITE_API_URL=https://api.get-nomox.com

# Private (server-side only, never exposed to browser)-used by the /api proxy route
# Production (Vercel): set to http://<your-vps-ip>:8000
BACKEND_URL=

# Waitlist form API key-server-side only, never exposed to browser
WAITLIST_API_KEY=

# Hotjar Settings
VITE_HOTJAR_ENABLED=false

# PostHog Settings
VITE_POSTHOG_ENABLED=false
VITE_POSTHOG_KEY=your-posthog-key
VITE_POSTHOG_HOST=https://eu.i.posthog.com

# Google Analytics Settings
VITE_MEASUREMENT_ID=your-measurement-id
